{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Claw",
  "scopeName": "source.claw",
  "patterns": [
    { "include": "#comments" },
    { "include": "#module" },
    { "include": "#signature" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#effectful" },
    { "include": "#tags" },
    { "include": "#qualified" },
    { "include": "#lambda" },
    { "include": "#definition" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.claw",
          "match": "#.*$"
        }
      ]
    },
    "module": {
      "patterns": [
        {
          "match": "^\\s*(module|app|platform|package|hosted|import|expose|exposing)\\b",
          "name": "keyword.control.module.claw"
        }
      ]
    },
    "signature": {
      "comment": "name : Type  — a standalone type signature line",
      "match": "^\\s*([a-z_][a-zA-Z0-9_]*!?)\\s*(:)\\s*(.+)$",
      "captures": {
        "1": { "name": "entity.name.function.claw" },
        "2": { "name": "keyword.operator.type-annotation.claw" },
        "3": { "patterns": [{ "include": "#types" }] }
      }
    },
    "types": {
      "patterns": [
        {
          "match": "\\b([A-Z][a-zA-Z0-9_]*)(\\.[A-Z][a-zA-Z0-9_]*)*\\b",
          "name": "entity.name.type.claw"
        },
        {
          "match": "\\b[a-z][a-zA-Z0-9_]*\\b",
          "name": "variable.other.generic-type.claw"
        },
        {
          "match": "->|=>|,",
          "name": "keyword.operator.arrow.claw"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(if|else|match|when|is|then|and|or|not|crash|expect|return|dbg)\\b",
          "name": "keyword.control.claw"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.claw",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.claw",
          "match": "\\\\(n|t|r|\\\\|\"|u\\{[0-9a-fA-F]+\\})"
        },
        {
          "name": "meta.embedded.interpolation.claw",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.claw" } },
          "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.claw" } },
          "patterns": [{ "include": "$self" }]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b0x[0-9a-fA-F_]+\\b|\\b[0-9][0-9_]*(\\.[0-9_]+)?\\b",
          "name": "constant.numeric.claw"
        }
      ]
    },
    "effectful": {
      "comment": "effectful calls and defs end with ! — the visible effect marker",
      "match": "\\b([a-z_][a-zA-Z0-9_]*!)",
      "name": "support.function.effectful.claw"
    },
    "tags": {
      "comment": "tag constructors: Ok, Err, Some, None, custom unions",
      "match": "\\b[A-Z][a-zA-Z0-9_]*\\b(?!\\s*\\.)",
      "name": "entity.name.tag.claw constant.other.claw"
    },
    "qualified": {
      "comment": "Module.function references — the CDB namespace",
      "match": "\\b([A-Z][a-zA-Z0-9_]*)(\\.)([a-z_][a-zA-Z0-9_]*!?)",
      "captures": {
        "1": { "name": "entity.name.namespace.claw" },
        "2": { "name": "punctuation.accessor.claw" },
        "3": { "name": "support.function.claw" }
      }
    },
    "lambda": {
      "comment": "|a, b| — lambda parameter list",
      "match": "(\\|)([^|]*)(\\|)",
      "captures": {
        "1": { "name": "punctuation.definition.parameters.begin.claw" },
        "2": { "patterns": [{ "match": "[a-z_][a-zA-Z0-9_]*", "name": "variable.parameter.claw" }] },
        "3": { "name": "punctuation.definition.parameters.end.claw" }
      }
    },
    "definition": {
      "match": "^\\s*([a-z_][a-zA-Z0-9_]*!?)\\s*(=)(?!=)",
      "captures": {
        "1": { "name": "entity.name.function.claw" },
        "2": { "name": "keyword.operator.assignment.claw" }
      }
    },
    "operators": {
      "match": "->|=>|==|!=|<=|>=|\\+|-|\\*|/|%|<|>|=",
      "name": "keyword.operator.claw"
    },
    "punctuation": {
      "match": "[{}\\[\\](),.]",
      "name": "punctuation.claw"
    }
  }
}
